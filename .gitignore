# ═══════════════════════════════════════════════
# INTELLISTRUCT – COMPOSITE BAR ANALYZER
# Master GitIgnore for Full-Stack Development
# ═══════════════════════════════════════════════

# --- Python / Backend ---
__pycache__/
*.py[cod]
*$py.class
.venv/
env/
venv/
ENV/
.env
backend/.env
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# --- Node.js / Frontend ---
node_modules/
frontend/node_modules/
dist/
frontend/dist/
build/
.DS_Store
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Environment Controls ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Reports & Outputs ---
reports/
!reports/.gitkeep
Report/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# --- OS Artifacts ---
Thumbs.db
desktop.ini
